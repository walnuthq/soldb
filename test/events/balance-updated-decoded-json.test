# Test JSON ABI decoding for an event with indexed and non-indexed arguments
# REQUIRES: soldb
# RUN: TX=$(cd %{project_root}/examples && DEBUG_DIR=out RPC_URL=%{rpc_url} PRIVATE_KEY=%{private_key} %S/interact-contract.sh send "updateBalance(address,uint256)" 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266 99 2>&1 | grep -o '0x[a-fA-F0-9]\{64\}' | head -1) && %soldb list-events $TX --ethdebug-dir %{contract_address}:TestContract:%{ethdebug_dir} --multi-contract --rpc %{rpc_url} --json-events 2>&1 | FileCheck %s

# CHECK: "events": [
# CHECK: "datas": [
# CHECK: "name": "user",
# CHECK: "type": "address",
# CHECK: "value": "0x{{[0-9a-f]+}}"
# CHECK: "name": "newBalance",
# CHECK: "type": "uint256",
# CHECK: "value": 99
# CHECK: "event": "BalanceUpdated",
# CHECK: "signature": "BalanceUpdated(address,uint256)"
# CHECK: "total_events": 1
