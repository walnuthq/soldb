# Test validation when --raw-data is combined with function arguments
# REQUIRES: soldb
# RUN: not %soldb simulate %{contract_address} "increment(uint256)" 1 --from 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266 --rpc-url %{rpc_url} --raw-data 0x1234 2>&1 | FileCheck %s

# CHECK: Error: When using --raw-data, do not provide function_signature or function_args.
