# Test top-level and subcommand help output
# REQUIRES: soldb
# RUN: %soldb --help 2>&1 | FileCheck %s --check-prefix=MAIN
# RUN: %soldb --version 2>&1 | FileCheck %s --check-prefix=VERSION
# RUN: %soldb trace --help 2>&1 | FileCheck %s --check-prefix=TRACE
# RUN: %soldb simulate --help 2>&1 | FileCheck %s --check-prefix=SIMULATE
# RUN: %soldb list-events --help 2>&1 | FileCheck %s --check-prefix=EVENTS
# RUN: %soldb list-contracts --help 2>&1 | FileCheck %s --check-prefix=CONTRACTS
# RUN: %soldb bridge --help 2>&1 | FileCheck %s --check-prefix=BRIDGE

# MAIN: usage:
# MAIN: SolDB - Ethereum transaction analysis tool
# MAIN: list-contracts
# MAIN: list-events
# MAIN: trace
# MAIN: simulate

# VERSION: 0.1.0

# TRACE: usage:
# TRACE: tx_hash
# TRACE: --ethdebug-dir
# TRACE: --multi-contract
# TRACE: --rpc, -r RPC
# TRACE: --json

# SIMULATE: usage:
# SIMULATE: --from FROM_ADDR
# SIMULATE: contract_address
# SIMULATE: function_signature
# SIMULATE: --raw-data RAW_DATA
# SIMULATE: --fork-url FORK_URL

# EVENTS: usage:
# EVENTS: tx_hash
# EVENTS: --ethdebug-dir
# EVENTS: --rpc-url, -r RPC_URL
# EVENTS: --json-events

# CONTRACTS: usage:
# CONTRACTS: tx_hash
# CONTRACTS: --rpc-url, -r RPC_URL
# CONTRACTS: --ethdebug-dir
# CONTRACTS: --multi-contract

# BRIDGE: usage:
# BRIDGE: --host HOST
# BRIDGE: --port PORT
# BRIDGE: --config CONFIG_FILE
# BRIDGE: --json
